{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Systemd": {
    "EnableMonitoring": true,
    "MetricCollectionIntervalMs": 5000,
    "LogRetentionDays": 90,
    "MaxLogEntriesPerRequest": 500,
    "EnableRemoteOperations": true,
    "OperationTimeoutMs": 30000,
    "ConnectionRetryCount": 5,
    "ConnectionRetryDelayMs": 2000,
    "EnableHealthChecks": true
  },
  "Database": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=db.internal;Username=systemd_monitor;Password=CHANGE_ME;Database=systemd_monitor;",
    "EnableLogging": false,
    "CommandTimeoutSeconds": 60,
    "MaxConnectionPoolSize": 30,
    "QueryCacheExpirationMinutes": 10
  },
  "Kestrel": {
    "Endpoints": {
      "HttpsInlineCertAndKey": {
        "Url": "https://0.0.0.0:5001",
        "Certificate": {
          "Path": "/etc/systemd-monitor/cert.pfx",
          "Password": "CHANGE_ME"
        }
      }
    },
    "Limits": {
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 20,
      "MaxRequestBodySize": 10485760,
      "MinRequestBodyDataRate": {
        "BytesPerSecond": 1024,
        "GracePeriod": "00:00:10"
      }
    }
  },
  "Swagger": {
    "Enabled": false,
    "Title": "systemd Service Monitor API",
    "Version": "1.0.0",
    "Description": "REST API for monitoring and managing systemd services via D-Bus"
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 100,
    "RequestsPerHour": 1000
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Ansi"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/systemd-monitor/app-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 104857600,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*",
  "CORS": {
    "AllowedOrigins": [
      "https://monitor.example.com"
    ],
    "AllowedMethods": [
      "GET",
      "POST"
    ]
  }
}
